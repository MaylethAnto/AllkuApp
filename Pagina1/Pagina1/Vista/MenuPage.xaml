<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pagina1.Vista.MenuPage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <StackLayout Padding="20">
        <Button Text="Agregar Mascota" Clicked="OnAddPetClicked"/>
        <Button Text="Perfil" Clicked="OnPerfilClicked"/>
        <Button Text="Ejercicio" Clicked="OnEjerciciosClicked"/>
        <Button Text="Dieta" Clicked="OnRecetasClicked"/>
        <Button Text="GPS" Clicked="OnGPSClicked"/>
        <Button Text="Cerrar Sesión" Clicked="OnLogoutClicked"/>
    </StackLayout>
</ContentPage>